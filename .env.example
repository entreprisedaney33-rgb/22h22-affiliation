# ─── Source de données ────────────────────────────────────────────
# "sheets" : utilise Google Sheets (par défaut en prod)
# "mock"   : utilise lib/mockData.ts (utile en local sans Sheets)
# Si "sheets" est choisi mais que l'appel échoue, le code retombe
# automatiquement sur les données mock (et logge l'erreur).
DATA_SOURCE=sheets

# ─── Google Sheets ────────────────────────────────────────────────
# Ces 3 variables doivent être configurées dans Vercel.
GOOGLE_SHEET_ID=
GOOGLE_CLIENT_EMAIL=
# Coller la clé privée avec ses retours à la ligne échappés (\n).
# Le code remplace automatiquement les \n littéraux par de vrais
# retours à la ligne au runtime.
GOOGLE_PRIVATE_KEY=

# ─── Site Shopify ─────────────────────────────────────────────────
NEXT_PUBLIC_SHOPIFY_URL=https://22h22foret.fr

# ─── NextAuth (réservé — pas encore utilisé pour le MVP) ──────────
# Le login MVP utilise un cookie HMAC custom signé par NEXTAUTH_SECRET.
NEXTAUTH_URL=
NEXTAUTH_SECRET=
